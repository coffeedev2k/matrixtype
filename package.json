{
  "name": "matrixtype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "local": "bash scripts/dev.sh",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "preview:local": "bash scripts/preview.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4"
  }
}
